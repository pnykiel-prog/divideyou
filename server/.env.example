# PostgreSQL connection string (e.g. Neon). Use the pooled connection URL for serverless.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
JWT_SECRET="change-me-to-a-long-random-string"
PORT=4000
FRONT_URL="http://localhost:5173"
# Secret guarding the one-time demo-data bootstrap endpoint (/api/bootstrap?secret=...)
SEED_SECRET="change-me"
